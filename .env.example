# ── Backend ───────────────────────────────────────────────────────────────────

# Gemini API key (Google AI Studio → https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Frontend build args ───────────────────────────────────────────────────────
# N8N webhook URLs — leave empty if not configured yet
# These are baked into the JS bundle at build time (VITE_ prefix required)

VITE_WEBHOOK_AUTHORITIES=
VITE_WEBHOOK_HOSPITALITY=
