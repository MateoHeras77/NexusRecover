# ── Backend ───────────────────────────────────────────────────────────────────

# Gemini API key (Google AI Studio → https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── N8N Webhooks ──────────────────────────────────────────────────────────────
# Backend proxies to these URLs — leave empty if not configured yet
# No need for VITE_ prefix; these are runtime variables only

WEBHOOK_AUTHORITIES=
WEBHOOK_HOSPITALITY=
